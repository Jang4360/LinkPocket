{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/protect-paths.sh",
            "timeout": 10,
            "statusMessage": "보호 경로 검사"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/gate-stop.sh",
            "timeout": 900
          }
        ]
      }
    ]
  }
}
